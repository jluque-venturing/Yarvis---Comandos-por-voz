# --- Credenciales obligatorias ---
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC...
# IDs de Telegram autorizados (coma-separado). SOLO estos IDs pueden dar ordenes.
TELEGRAM_ALLOWED_USER_IDS=111111111

# --- Orquestador (Claude) ---
ORCHESTRATOR_MODEL=claude-sonnet-5
ORCHESTRATOR_MAX_TOKENS=2048

# --- STT (voz -> texto, faster-whisper) ---
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- TTS (texto -> voz) ---
TTS_ENGINE=local

# --- Seguridad ---
CONFIRM_DANGEROUS=true

# --- Fase 4: modo llamada por voz (web local sobre Tailscale) ---
ENABLE_VOICE_CALL=false
VOICE_CALL_HOST=127.0.0.1
VOICE_CALL_PORT=8760

# --- Modo del asistente ---
# claude_code = Jarvis maneja tu Claude Code (recomendado; no necesita ANTHROPIC_API_KEY)
# pc_tools    = Jarvis controla la PC directo por la API (modo original; SI necesita la key)
ASSISTANT_MODE=claude_code

# --- Modo claude_code ---
CLAUDE_CODE_CMD=claude
# IMPORTANTE: apuntar a la carpeta del proyecto que Jarvis debe manejar.
CLAUDE_CODE_PROJECT_DIR=C:\Proyectos\mi-proyecto
# true = propone un plan y espera "si, confirmo" antes de tocar archivos (estilo Claude)
CLAUDE_CODE_CONFIRM=true
CLAUDE_CODE_TIMEOUT=300
